# Public Supabase project URL used by the app and server-side Supabase client.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase project URL used by trusted scripts and server jobs; usually matches NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=

# Public Supabase anon key used for browser-safe and server-side authenticated Supabase requests.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Private Supabase service role key reserved for trusted server-side jobs and admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# Spotify application client ID used for Spotify API integration.
SPOTIFY_CLIENT_ID=

# Spotify application client secret used only from trusted server-side code.
SPOTIFY_CLIENT_SECRET=
